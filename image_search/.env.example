# Image Search Configuration

# Server
IMAGE_SEARCH_HOST=0.0.0.0
IMAGE_SEARCH_PORT=8000
IMAGE_SEARCH_DEBUG=true

# File upload
IMAGE_SEARCH_UPLOAD_DIR=uploads
IMAGE_SEARCH_MAX_FILE_SIZE_MB=20

# Search settings
IMAGE_SEARCH_MAX_RESULTS=20
IMAGE_SEARCH_TIMEOUT=30

# === API Keys (get these to enable each search engine) ===

# Google via SerpAPI - https://serpapi.com/
SERPAPI_KEY=

# Bing Visual Search - https://www.microsoft.com/en-us/bing/apis/bing-visual-search-api
BING_API_KEY=

# TinEye - https://tineye.com/developer
TINEYE_API_KEY=

# CLIP model (optional)
CLIP_MODEL=ViT-B/32
CLIP_INDEX_DIR=clip_index
